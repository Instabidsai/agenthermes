          { "name": "slug", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": { "description": "Mystery shop history with pagination" }
        }
      }
    },
    "/api/v1/analytics": {
      "get": {
        "summary": "Get business analytics",
        "description": "Returns analytics for a business including views, searches, transactions, search queries, top agents, and gateway usage. Auth required.",
        "operationId": "getAnalytics",
        "tags": ["Analytics"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
