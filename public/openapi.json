        "operationId": "triggerMonitoring",
        "tags": ["Monitoring"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Monitoring cycle results" },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Rate limit exceeded" }
        }
      }
    },
    "/api/v1/mystery-shop": {
      "post": {
        "summary": "Trigger mystery shop",
        "description": "Run a mystery shop test on a business's agent-facing services. Auth required.",
        "operationId": "runMysteryShop",
        "tags": ["Monitoring"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "business_id": { "type": "string", "format": "uuid" },
                  "slug": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Mystery shop results" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Business not found" }
        }
      },
      "get": {
        "summary": "Get mystery shop history",
        "description": "Retrieve past mystery shop results for a business.",
        "operationId": "getMysteryShopHistory",
        "tags": ["Monitoring"],
        "parameters": [
